    {
      "parameters": {
        "jsCode": "const output = items[0].json.output;\n// Puxa o e-mail direto da planilha para não ter erro\nconst email = items[0].json.email || items[0].json.emails; \n\nconst lines = output.split('\\n');\nconst subject = lines[0].replace('Subject: ', '').trim();\n\n// Remove o subject do corpo e limpa espaços\nlet body = lines.slice(1).join('\\n').trim();\n\n// Transforma o texto em HTML amigável\nconst htmlMessage = `\n  <div style=\"font-family: 'Segoe UI', Arial, sans-serif; font-size: 16px; color: #333; line-height: 1.6;\">\n    ${body.replace(/\\n/g, '<br>')}\n  </div>\n`;\n\nreturn [{\n  json: {\n    subject: subject,\n    message: htmlMessage,\n    email: email\n  }\n}];"
      },
